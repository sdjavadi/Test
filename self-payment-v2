# Self-Payment Detection — Scoring Pipeline (Final)
# Outputs: similarity score, normalized names, suffixes, FI info, MDM IDs
# No alert tiers, no cap flag, no match_tier column

from pyspark.sql import functions as F
from pyspark.sql.functions import col, lower, trim, regexp_replace, when, length
from functools import reduce
from pyspark.sql import DataFrame
import pandas as pd

TABLE   = "xxx.yyy"
OUT_DB  = "xxx"
OUT_TBL = "self_payment_candidates"

# ─────────────────────────────────────────────
# SECTION 1 — Configuration
# ─────────────────────────────────────────────

