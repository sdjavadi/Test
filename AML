// Target PAYS TO intermediaries, intermediaries PAY TO candidates
// Excludes hub nodes from intermediary role

MATCH (target:PncCustomer {mdmid: $target_mdmid})

// Out-neighbors of target (target pays these)
MATCH (target)-[:PAYS]->(intermediary:PncCustomer)
WHERE NOT intermediary.mdmid IN $hub_nodes
  AND intermediary <> target

// Candidates that intermediaries pay to
MATCH (intermediary)-[:PAYS]->(candidate:PncCustomer)
WHERE candidate <> target
  AND NOT candidate.mdmid IN $hub_nodes

WITH target, candidate,
     collect(DISTINCT intermediary) AS shared_intermediaries
WHERE size(shared_intermediaries) >= $y

RETURN
  target.mdmid                                    AS target_mdmid,
  candidate.mdmid                                 AS candidate_mdmid,
  size(shared_intermediaries)                     AS shared_count,
  [n IN shared_intermediaries | n.mdmid]          AS intermediary_mdmids
ORDER BY shared_count DESC
LIMIT $k
