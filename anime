# Add this to sidebar (keep if already there)
top_n_drifters = st.sidebar.slider("Highlight top N drifters", 5, 50, 10)

# Precompute segments for top movers per step (replace your current segments block with this)
times = sorted(df['time'].unique())
segments = {}  # dict keyed by step number
for i in range(1, len(times)):
    prev_time = times[i-1]
    curr_time = times[i]
    prev = df[df['time'] == prev_time].set_index('cust_pvr_id')
    curr = df[df['time'] == curr_time].set_index('cust_pvr_id')
    common = list(set(prev.index) & set(curr.index))  # list to avoid set issues
    if common:
        prev_pos = prev.reindex(common)[['x', 'y']]
        curr_pos = curr.reindex(common)[['x', 'y']]
        dists = np.sqrt(((curr_pos - prev_pos)**2).sum(axis=1))
        top = dists.nlargest(top_n_drifters).index
        segments[i] = []  # per step segments
        for id in top:
            segments[i].append({
                'x_start': prev_pos.loc[id]['x'],
                'y_start': prev_pos.loc[id]['y'],
                'x_end': curr_pos.loc[id]['x'],
                'y_end': curr_pos.loc[id]['y'],
                'id': id
            })

# Manual step control (keep your current, but add animation feel with sleep for slow build)
import time
if 'current_index' not in st.session_state:
    st.session_state.current_index = 0

col1, col2 = st.columns(2)
if col1.button('Previous Step'):
    st.session_state.current_index = max(0, st.session_state.current_index - 1)
if col2.button('Next Step'):
    st.session_state.current_index = min(len(times) - 1, st.session_state.current_index + 1)

current_index = st.session_state.current_index
current_step = current_index + 1 if current_index > 0 else 1  # 1-based
current_time = times[current_index]
current_df = df[df['time'] == current_time]

# Identify top drifters for THIS transition (if not first step)
top_ids_this_step = []
if current_index > 0:
    top_ids_this_step = [seg['id'] for seg in segments.get(current_step, [])]

fig = go.Figure()

# Add arrow ONLY for the immediate previous transition (vanishes on next click)
if current_index > 0:
    for seg in segments.get(current_step, []):
        fig.add_trace(go.Scatter(
            x=[seg['x_start'], seg['x_end']],
            y=[seg['y_start'], seg['y_end']],
            mode='lines+markers',
            marker=dict(symbol='arrow', size=15, angleref="previous"),
            line=dict(color='red', width=2),
            showlegend=False
        ))
    time.sleep(1.5)  # Slow "build" pause — feels like arrow is drawing slowly

# Add all points at current time (distinct colors: red for top drifters, blue for others)
fig.add_trace(go.Scatter(
    x=current_df[~current_df['cust_pvr_id'].isin(top_ids_this_step)]['x'],
    y=current_df[~current_df['cust_pvr_id'].isin(top_ids_this_step)]['y'],
    mode='markers',
    marker=dict(color='blue', size=10),
    text=current_df[~current_df['cust_pvr_id'].isin(top_ids_this_step)]['cust_pvr_id'],
    hovertemplate='<b>ID:</b> %{text}<extra></extra>',
    name='Regular Customers'
))

fig.add_trace(go.Scatter(
    x=current_df[current_df['cust_pvr_id'].isin(top_ids_this_step)]['x'],
    y=current_df[current_df['cust_pvr_id'].isin(top_ids_this_step)]['y'],
    mode='markers',
    marker=dict(color='red', size=12),
    text=current_df[current_df['cust_pvr_id'].isin(top_ids_this_step)]['cust_pvr_id'],
    hovertemplate='<b>ID:</b> %{text} (Top Drifter)<extra></extra>',
    name='Top Drifters'
))

fig.update_layout(
    title=f"Customer Map at {current_time} (Step {current_step}/{len(times)})",
    xaxis_title="UMAP 1", yaxis_title="UMAP 2",
    height=800,
    hovermode='closest',
    transition=dict(duration=1500)  # Slow transition for points moving
)

st.plotly_chart(fig, use_container_width=True)
