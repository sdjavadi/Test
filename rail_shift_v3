# ─── Behavioral metrics ───────────────────────────────────────────────────────

def peak_zscore(df_list: list) -> float:
    """
    Max absolute z-score across all rails and months, computed against
    the customer's own monthly history. Catches sudden one-off spikes.
    """
    slices = [d for d in df_list if not d.empty]
    if not slices:
        return 0.0
    combined = pd.concat(slices, ignore_index=True)
    max_z = 0.0
    for r in RAILS:
        monthly = combined.groupby("time_key")[r].sum()
        if len(monthly) < 2:
            continue
        std = monthly.std()
        if std == 0:
            continue
        z = ((monthly - monthly.mean()) / std).abs().max()
        max_z = max(max_z, float(z))
    return round(max_z, 2)


def rail_debuts_exits(df_list: list) -> int:
    """
    Count rail channel appearances (0→>0) and disappearances (>0→0)
    across the time window. One Wire spike that appears and vanishes = 2.
    """
    slices = [d for d in df_list if not d.empty]
    if not slices:
        return 0
    combined = pd.concat(slices, ignore_index=True)
    count = 0
    for r in RAILS:
        monthly = combined.groupby("time_key")[r].sum().sort_index()
        if len(monthly) < 2:
            continue
        active = (monthly > 0).astype(int)
        diffs = active.diff().dropna()
        count += int((diffs == 1).sum())   # debuts
        count += int((diffs == -1).sum())  # exits
    return count


def compute_hhi(rail_sums: dict) -> float:
    total = sum(rail_sums.values())
    if total == 0:
        return float("nan")
    return round(sum((v / total) ** 2 for v in rail_sums.values()), 4)


def dominant_rail(rail_sums: dict) -> str:
    if not any(rail_sums.values()):
        return "None"
    return max(rail_sums, key=rail_sums.get)


