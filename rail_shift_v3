        rail_sums = {}
        for r in RAILS:
            rail_sums[r] = (float(cs[r].sum())  if not cs.empty  else 0.0) + \
                           (float(cps[r].sum()) if not cps.empty else 0.0)

        # Active months
        months_seen = set()
        if not cs.empty:
            months_seen.update(cs["time_key"].dropna().unique())
        if not cps.empty:
            months_seen.update(cps["time_key"].dropna().unique())

        # Behavioral metrics
        # Peak Z-Score: uses unfiltered-by-direction slices since z-score is
        # against the customer's own baseline — needs all months present.
        # We use the same direction/nodetype-filtered slices for consistency.
        pz  = peak_zscore([cs, cps])
        rde = rail_debuts_exits([cs, cps])
        hhi = compute_hhi(rail_sums)
        dom = dominant_rail(rail_sums)
        dom_amt = rail_sums.get(dom, 0.0)

        records.append({
            "mdmId":          focal,
            "In-Flow":        in_flow,
            "Out-Flow":       out_flow,
            "Net-Flow":       net_flow,
            "In-Degree":      in_deg,
            "Out-Degree":     out_deg,
            "Total Amount":   total,
            "ACH":            rail_sums["ACH"],
            "Wire":           rail_sums["Wire"],
            "Check":          rail_sums["Check"],
            "RTP":            rail_sums["RTP"],
            "Debit":          rail_sums["Debit"],
            "Peak Z-Score":   pz,
            "Rail Debuts/Exits": rde,
            "HHI":            hhi,
            "Dominant Rail":  dom,
            "_dom_amt":       dom_amt,   # used for percentile, dropped later
            "Active Months":  len(months_seen),
        })

    if not records:
        st.info("No customers match the selected filters.")
        st.stop()

    result_df = pd.DataFrame(records)

    # ── Pass 2: Dominant Rail Percentile ─────────────────────────────────────
    # For each customer, rank their dominant-rail amount among all peers
    # who share the same dominant rail — then express as 0-100 percentile.
    def dom_percentile(row, df):
        rail = row["Dominant Rail"]
        if rail == "None":
            return float("nan")
        peer_amounts = df[df["Dominant Rail"] == rail]["_dom_amt"]
        if len(peer_amounts) < 2:
            return float("nan")
        pct = (peer_amounts < row["_dom_amt"]).sum() / len(peer_amounts) * 100
        return round(pct, 1)

    result_df["Dom. Rail Pct."] = result_df.apply(
        dom_percentile, axis=1, df=result_df
    )
    result_df.drop(columns=["_dom_amt"], inplace=True)
    result_df.sort_values("Total Amount", ascending=False, inplace=True)

    # ── Display ───────────────────────────────────────────────────────────────
    st.markdown(
        f"**{len(result_df):,} customers** · "
        f"Direction: `{direction_sel}` · Node type: `{node_type_sel}`"
    )
    st.caption(
        "**Peak Z-Score** — largest absolute deviation from this customer's own monthly rail baseline "
        "(high value = a sudden rail spike appeared).  "
        "**Rail Debuts/Exits** — number of times a rail channel switched on (0→>0) or off (>0→0) "
        "across the period (e.g. Wire appears for one month then vanishes = 2).  "
        "**HHI** — rail concentration index (1.0 = all volume on one rail).  "
        "**Dominant Rail** — the payment channel carrying the most volume for this customer.  "
        "**Dom. Rail Pct.** — percentile of this customer's dominant-rail volume among NAICS peers "
        "sharing the same dominant rail (94 = heavier user than 94% of peers)."
    )

    st.dataframe(
        result_df,
        use_container_width=True,
        hide_index=True,
        column_config={
            "In-Flow":           AMT_COL,
            "Out-Flow":          AMT_COL,
            "Net-Flow":          AMT_COL,
            "Total Amount":      AMT_COL,
            "ACH":               AMT_COL,
            "Wire":              AMT_COL,
            "Check":             AMT_COL,
            "RTP":               AMT_COL,
            "Debit":             AMT_COL,
            "Peak Z-Score":      st.column_config.NumberColumn(format="%.2f"),
            "Rail Debuts/Exits": INT_COL,
            "HHI":               st.column_config.NumberColumn(format="%.4f"),
            "Dominant Rail":     st.column_config.TextColumn(),
            "Dom. Rail Pct.":    st.column_config.NumberColumn(format="%.1f"),
            "In-Degree":         INT_COL,
            "Out-Degree":        INT_COL,
            "Active Months":     INT_COL,
        },
    )
