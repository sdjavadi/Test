# ─── Neo4j ────────────────────────────────────────────────────────────────────

@st.cache_resource
def get_driver():
    return GraphDatabase.driver(NEO4J_URI, auth=(NEO4J_USER, NEO4J_PASSWORD))


def run_query(cypher: str, params: dict = None) -> list:
    driver = get_driver()
    with driver.session(database=NEO4J_DATABASE) as session:
        return [dict(r) for r in session.run(cypher, params or {})]


@st.cache_data(show_spinner="Loading NAICS codes…")
def load_naics() -> list:
    rows = run_query("""
        MATCH (n:PncCustomer)
        WHERE n.naics IS NOT NULL AND n.naics <> ''
        RETURN DISTINCT n.naics AS naics ORDER BY naics
    """)
    return [r["naics"] for r in rows]


# ─── Cypher queries ───────────────────────────────────────────────────────────

CUSTOMER_Q = """
MATCH (c:PncCustomer {naics: $naics})-[r:PAYS]-(other:PncCustomer)
WHERE r.time_key >= date($start_date) AND r.time_key <= date($end_date)
RETURN
  c.mdmId                              AS focal_id,
  other.mdmId                          AS other_id,
  coalesce(other.naics, 'Unknown')     AS other_naics,
  startNode(r).mdmId                   AS from_id,
  endNode(r).mdmId                     AS to_id,
  coalesce(r.totalTransAmtACH,   0.0)  AS ACH,
  coalesce(r.totalTransAmtWire,  0.0)  AS Wire,
  coalesce(r.totalTransAmtR2P,   0.0)  AS RTP,
  coalesce(r.totalTransAmtCheck, 0.0)  AS Check,
  coalesce(r.totalTransAmtDebit, 0.0)  AS Debit,
  coalesce(r.totalTransAmt,      0.0)  AS total_amt,
  coalesce(r.transFreq,          0)    AS freq,
  toString(r.time_key)                 AS time_key
"""

CPTY_Q = """
MATCH (c:PncCustomer {naics: $naics})-[r:PAYS_CPTY]->(cpty:Counterparty)
WHERE r.time_key >= date($start_date) AND r.time_key <= date($end_date)
RETURN
  c.mdmId                                                AS customer_id,
  coalesce(cpty.cptyNamePrmry, toString(cpty.unqCptyId)) AS cpty_label,
  toString(cpty.unqCptyId)                               AS cpty_id,
  'outgoing'                                             AS direction,
  coalesce(r.totalTransAmtACH,   0.0)                   AS ACH,
  coalesce(r.totalTransAmtWire,  0.0)                   AS Wire,
  coalesce(r.totalTransAmtR2P,   0.0)                   AS RTP,
  coalesce(r.totalTransAmtCheck, 0.0)                   AS Check,
  coalesce(r.totalTransAmtDebit, 0.0)                   AS Debit,
  coalesce(r.totalTransAmt,      0.0)                   AS total_amt,
  coalesce(r.transFreq,          0)                     AS freq,
  toString(r.time_key)                                   AS time_key
UNION ALL
MATCH (c:PncCustomer {naics: $naics})<-[r:CPTY_PAYS]-(cpty:Counterparty)
WHERE r.time_key >= date($start_date) AND r.time_key <= date($end_date)
RETURN
  c.mdmId                                                AS customer_id,
  coalesce(cpty.cptyNamePrmry, toString(cpty.unqCptyId)) AS cpty_label,
  toString(cpty.unqCptyId)                               AS cpty_id,
  'incoming'                                             AS direction,
  coalesce(r.totalTransAmtACH,   0.0)                   AS ACH,
  coalesce(r.totalTransAmtWire,  0.0)                   AS Wire,
  coalesce(r.totalTransAmtR2P,   0.0)                   AS RTP,
  coalesce(r.totalTransAmtCheck, 0.0)                   AS Check,
  coalesce(r.totalTransAmtDebit, 0.0)                   AS Debit,
  coalesce(r.totalTransAmt,      0.0)                   AS total_amt,
  coalesce(r.transFreq,          0)                     AS freq,
  toString(r.time_key)                                   AS time_key
"""


# ─── Utility functions ────────────────────────────────────────────────────────

def fmt_usd(v: float) -> str:
    """Human-readable USD for st.metric() only — not for table cells."""
    av = abs(v)
    if av >= 1e9: return f"${v/1e9:,.2f}B"
    if av >= 1e6: return f"${v/1e6:,.2f}M"
    if av >= 1e3: return f"${v/1e3:,.1f}K"
    return f"${v:,.0f}"


def rail_pct(df: pd.DataFrame) -> dict:
    totals = {r: float(df[r].sum()) for r in RAILS}
    grand = sum(totals.values()) or 1.0
    return {r: round(v / grand * 100, 1) for r, v in totals.items()}


def donut_chart(pct_dict: dict, title: str):
    non_zero = {k: v for k, v in pct_dict.items() if v > 0}
    if not non_zero:
        fig = go.Figure()
        fig.update_layout(title=title, height=220,
                          annotations=[{"text": "No data", "showarrow": False}])
        return fig
    fig = go.Figure(go.Pie(
        labels=list(non_zero.keys()),
        values=list(non_zero.values()),
        hole=0.5,
        marker_colors=[RAIL_COLORS[r] for r in non_zero],
        textinfo="label+percent",
        textfont_size=11,
    ))
    fig.update_layout(
        title=dict(text=title, font_size=13),
        showlegend=False, height=230,
        margin=dict(t=36, b=4, l=4, r=4),
    )
    return fig


def stacked_bar(df: pd.DataFrame, title: str):
    if df.empty:
        fig = go.Figure()
        fig.update_layout(title=title, height=300,
                          annotations=[{"text": "No data", "showarrow": False}])
        return fig
    grp = df.groupby("time_key")[RAILS].sum().reset_index().sort_values("time_key")
    fig = go.Figure()
    for rail in RAILS:
        if grp[rail].sum() == 0:
            continue
        fig.add_trace(go.Bar(
            name=rail, x=grp["time_key"], y=grp[rail],
            marker_color=RAIL_COLORS[rail],
        ))
    fig.update_layout(
        barmode="stack",
        title=dict(text=title, font_size=13),
        xaxis_title="Month", yaxis_title="Amount",
        xaxis_tickangle=-45, legend_title_text="Rail",
        height=310, margin=dict(t=40, b=40, l=40, r=10),
    )
    return fig


def top5_df(df: pd.DataFrame, group_col: str, label: str) -> pd.DataFrame:
    """Return top-5 by total_amt — amounts kept numeric for sortable display."""
    if df.empty:
        return pd.DataFrame(columns=[label, "Volume"])
    grp = (df.groupby(group_col)["total_amt"]
             .sum().sort_values(ascending=False).head(5).reset_index())
    grp.columns = [label, "Volume"]
    return grp  # Volume stays numeric


