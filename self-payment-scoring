# ─────────────────────────────────────────────

print("\n" + "=" * 65)
print("SCORING PIPELINE SUMMARY")
print("=" * 65)
print(f"Base filtered rows (outgoing Wire+ACH): {base_count:,}")
print(f"Tier 1  exact matches                : {tier1_count:,}")
print(f"Tier 1b suffix variant matches       : {tier1b_count:,}")
print(f"Tier 2  fuzzy matches (JW>={JW_THRESHOLD}): {tier2_count:,}")
print(f"Distinct pairs scored (Jaro-Winkler) : {len(pairs_pd):,}")
print(f"Pairs above threshold                : {len(scored_pd):,}")
print(f"Final deduplicated candidates        : {final_count:,}")
print(f"Output table                         : {output_table}")
