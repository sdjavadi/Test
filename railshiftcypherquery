
MATCH (c:PncCustomer)-[r:PAYS]->(n:PncCustomer)
WHERE c.naics STARTS WITH $naics_prefix
  AND r.time_key >= date($start_date)
  AND r.time_key <= date($end_date)
  AND NOT c.customerId IN $hub_exclusion_list
  AND NOT n.customerId IN $hub_exclusion_list
WITH
  c.customerId          AS customer_id,
  c.customerName        AS customer_name,
  c.naics               AS naics,
  r.time_key            AS month,
  sum(r.totalTransAmt)      AS total_vol,
  sum(r.totalTransAmtACH)   AS ach_vol,
  sum(r.totalTransAmtWire)  AS wire_vol,
  sum(r.totalTransAmtR2P)   AS r2p_vol,
  sum(r.totalTransAmtCheck) AS check_vol,
  sum(r.totalTransAmtDebit) AS debit_vol
RETURN
  customer_id,
  customer_name,
  naics,
  month,
  total_vol,
  round(100.0 * ach_vol   / total_vol, 2) AS ach_pct,
  round(100.0 * wire_vol  / total_vol, 2) AS wire_pct,
  round(100.0 * r2p_vol   / total_vol, 2) AS r2p_pct,
  round(100.0 * check_vol / total_vol, 2) AS check_pct,
  round(100.0 * debit_vol / total_vol, 2) AS debit_pct
ORDER BY customer_id, month
